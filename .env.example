# ─── Окружение ───────────────────────────────────────────────────────────────
# Режим работы: production | development
ENVIRONMENT=production

# ─── Домены ──────────────────────────────────────────────────────────────────
# Корневой домен (используется в certbot для получения сертификатов)
DOMAIN=krichigindocs.ru

# Поддомен Mini App (React SPA)
MINIAPP_HOST=englishbot.krichigindocs.ru

# Поддомен Backend API (FastAPI)
API_HOST=api-english.krichigindocs.ru

# Поддомен Admin панели (React SPA)
ADMIN_HOST=admin-english.krichigindocs.ru

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Токен бота из @BotFather
BOT_TOKEN=xxx

# Секрет для проверки подписи Telegram Webhook (X-Telegram-Bot-Api-Secret-Token)
BOT_WEBHOOK_SECRET=xxx

# Полный URL Mini App — передаётся боту для кнопки "Начать разговор"
MINIAPP_URL=https://englishbot.krichigindocs.ru

# ─── Gemini AI ───────────────────────────────────────────────────────────────
# API-ключ Google Gemini (получить: https://aistudio.google.com/app/apikey)
# Обязателен для голосового режима (Phase 2)
GEMINI_API_KEY=

# Модель Gemini для нативного аудио-диалога (native speech-to-speech)
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Голос AI-репетитора
# Варианты: Puck, Charon, Kore, Fenrir, Aoede, Zephyr
# Puck  — нейтральный мужской
# Charon — глубокий мужской
# Kore  — мягкий женский
# Fenrir — энергичный мужской
# Aoede  — мягкий женский, тёплый
# Zephyr — лёгкий, нейтральный
GEMINI_VOICE=Puck

# ─── Admin Panel ─────────────────────────────────────────────────────────────
# JWT-секрет для аутентификации в admin-панели
# Сгенерировать: openssl rand -hex 32
ADMIN_JWT_SECRET=change_me_with_openssl_rand_hex_32

# ─── Let's Encrypt ───────────────────────────────────────────────────────────
# Email для уведомлений об истечении сертификатов
LETSENCRYPT_EMAIL=nutakoe27@gmail.com
