# ─── Окружение ───────────────────────────────────────────────────────────────
# Режим работы: production | development
ENVIRONMENT=production

# ─── Домены ──────────────────────────────────────────────────────────────────
# Корневой домен (используется в certbot для получения сертификатов)
DOMAIN=krichigindocs.ru

# Поддомен Mini App (React SPA)
MINIAPP_HOST=englishbot.krichigindocs.ru

# Поддомен Backend API (FastAPI)
API_HOST=api-english.krichigindocs.ru

# Поддомен Admin панели (React SPA)
ADMIN_HOST=admin-english.krichigindocs.ru

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Токен бота из @BotFather
BOT_TOKEN=xxx

# Username бота без '@' (например kmo_ai_english_bot).
# Пробрасывается в mini app на этапе docker build в качестве VITE_BOT_USERNAME.
# Нужен для deep-link «Перейти к подписке» на экране «Лимит исчерпан».
BOT_USERNAME=kmo_ai_english_bot

# Секрет для проверки подписи Telegram Webhook (X-Telegram-Bot-Api-Secret-Token)
BOT_WEBHOOK_SECRET=xxx

# Полный URL Mini App — передаётся боту для кнопки "Начать разговор"
MINIAPP_URL=https://englishbot.krichigindocs.ru

# ─── Voice pipeline (self-hosted на GPU-сервере) ─────────────────────────────
# Бэкенд полностью self-hosted: vLLM (LLM) + Whisper (STT) + Kokoro (TTS).
# Все три сервиса крутятся на V100 и пробрасываются на VPS через reverse SSH.

# ── LLM (vLLM, OpenAI-compatible) ──
# Базовый URL OpenAI-совместимого API vLLM (без /chat/completions)
VLLM_BASE_URL=http://host.docker.internal:23333/v1
# Имя модели (должно совпадать с --served-model-name у vLLM)
VLLM_MODEL_NAME=QuantTrio/Qwen3.5-35B-A3B-AWQ
# API-ключ, если настроен у vLLM (можно оставить пустым)
VLLM_API_KEY=

# ── STT (Whisper WebSocket) ──
# WebSocket URL до Whisper STT
WHISPER_STT_URL=ws://host.docker.internal:23334/ws
# Язык распознавания (ISO-639-1): en, ru, auto
WHISPER_STT_LANGUAGE=en

# ── TTS (Kokoro WebSocket) ──
# WebSocket URL до Kokoro TTS
KOKORO_TTS_URL=ws://host.docker.internal:23335/ws
# Голос Kokoro (af_heart, af_bella, am_adam, bm_george и др.)
KOKORO_TTS_VOICE=af_heart
# Скорость речи (1.0 — нормальная)
KOKORO_TTS_SPEED=1.0

# ─── Admin Panel ─────────────────────────────────────────────────────────────
# JWT-секрет для аутентификации в admin-панели (зарезервировано на будущее)
# Сгенерировать: openssl rand -hex 32
ADMIN_JWT_SECRET=change_me_with_openssl_rand_hex_32

# Статический токен доступа к admin REST API (X-Admin-Token).
# Используется фронтендом admin (вводится на экране логина) и
# проверяется backend во всех /api/admin/* эндпоинтах.
# Если пусто — admin API вернёт 503 и панель работать не будет.
# Сгенерировать: openssl rand -hex 32
ADMIN_TOKEN=

# ─── Let's Encrypt ───────────────────────────────────────────────────────────
# Email для уведомлений об истечении сертификатов
LETSENCRYPT_EMAIL=nutakoe27@gmail.com

# ─── База данных (MySQL) ─────────────────────────────────────────────────────
# Формат SQLAlchemy + aiomysql.
# На VPS: контейнер бэкенда подключается к хостовому MySQL через
#         host.docker.internal (требуется extra_hosts в docker-compose.yml).
DATABASE_URL=mysql+aiomysql://englishbot:CHANGEME@host.docker.internal:3306/englishbot?charset=utf8mb4

# ─── Админы ──────────────────────────────────────────────────────────────────
# Telegram ID администраторов через запятую. Узнать свой ID можно у @userinfobot.
ADMIN_IDS=

# ─── Платежи (Telegram Payments + ЮКасса) ────────────────────────────────────
# Провайдер-токен ЮКассы. Выдаёт @BotFather:
#   /mybots → @<бот> → Payments → YooKassa → авторизация в ЛК ЮКассы → выбрать ShopID.
# Формат обычно: 381764678:TEST:xxxxxxxx (тест) или 381764678:LIVE:xxxxxxxx (бой).
YOOKASSA_PROVIDER_TOKEN=

# ShopID из ЛК ЮКассы. Используется для логов и notes в записях payments
# (в нативной интеграции запросы идут через Telegram — бот в ЮКассу напрямую не ходит).
YOOKASSA_SHOP_ID=

# Фискализация (54-ФЗ): 1 = включена (передаём receipt + требуем email), 0 = выкл.
# Обязательна при работе через онлайн-кассу ЮКассы (ООО/ИП).
YOOKASSA_FISCALIZATION=1

# Ставка НДС в чеке: 1=без НДС (УСН/ПСН/ИП), 2=0%, 3=10%, 4=20%, 5=10/110, 6=20/120.
YOOKASSA_VAT_CODE=1
